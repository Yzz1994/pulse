PULSE_SERVER_ADDR=:8080
PULSE_ADMIN_USERNAME=admin
PULSE_ADMIN_PASSWORD=change-me

# PostgreSQL 连接串
# PULSE_DATABASE_URL=postgres://user:pass@host:5432/pulse?sslmode=disable

# 工作目录（geoip 数据库、上传文件等），默认 ./data
PULSE_DATA_DIR=/var/lib/pulse

PULSE_WEB_DIR=/usr/local/share/pulse/web/panel
PULSE_SERVER_NODE_CLIENT_CERT_FILE=/etc/pulse/server_client_cert.pem
PULSE_SERVER_NODE_CLIENT_KEY_FILE=/etc/pulse/server_client_key.pem

# Discourse SSO（可选，不填则禁用）
# PULSE_DISCOURSE_URL=https://your-forum.example.com
# PULSE_DISCOURSE_SSO_SECRET=your-sso-secret
# PULSE_DISCOURSE_ADMIN_USERS=alice,bob

# Stripe 商店（可选，配置 SECRET_KEY 后自动启用商店）
# PULSE_STRIPE_SECRET_KEY=sk_live_xxx
# PULSE_STRIPE_WEBHOOK_SECRET=whsec_xxx
